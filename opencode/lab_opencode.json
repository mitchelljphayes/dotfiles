{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "lab_linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "hostinger-mcp": {
      "type": "local",
      "command": ["npx", "-y", "hostinger-api-mcp@latest"],
      "environment": {
        "API_TOKEN": "{env:HOSTINGER_API_TOKEN}"
      }
    }
  }
}
