{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "opencode/gpt-5-nano",
  "plugin": ["@ex-machina/opencode-anthropic-auth"],
  "permission": {
    "websearch": "allow",
    "bash": {
      "* /tmp/*": "allow",
      "* /private/tmp/*": "allow",
      "gh pr merge *": "ask",
      "gh pr merge": "ask",
      "git push --force *": "ask",
      "git push -f *": "ask",
      "git push --force-with-lease *": "ask",
      "git reset --hard *": "ask",
      "git branch -D *": "ask",
      "git clean -f *": "ask",
      "git rebase *": "ask",
      "git checkout -- *": "ask",
      "gh pr close *": "ask",
      "gh repo delete *": "deny",
      "find*-delete *": "ask",
      "find*--delete *": "ask",
      "rm *": "ask",
      "rm -rf *": "ask",
      "rm -r *": "ask",
      "rm -f *": "ask",
      "rmdir *": "ask",
      "but setup": "allow",
      "but teardown": "ask",
      "but status *": "allow",
      "but status": "allow",
      "but diff *": "allow",
      "but diff": "allow",
      "but show *": "allow",
      "but branch *": "allow",
      "but branch": "allow",
      "but commit *": "allow",
      "but rub *": "allow",
      "but stage *": "allow",
      "but absorb *": "allow",
      "but absorb": "allow",
      "but mark *": "allow",
      "but unmark *": "allow",
      "but unmark": "allow",
      "but push *": "allow",
      "but push": "allow",
      "but pull *": "allow",
      "but pull": "allow",
      "but pr *": "allow",
      "but squash *": "allow",
      "but oplog": "allow",
      "but oplog snapshot *": "allow",
      "but undo": "ask",
      "but oplog restore *": "ask",
      "but resolve *": "ask"
    }
  },
  "instructions": ["AGENTS.md", "CLAUDE.md", ".cursor/rules/*.md"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--output-dir",
        ".screenshots"
      ],
      "timeout": 30000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "provider": {
    "google": {
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
