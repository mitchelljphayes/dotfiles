# Ghostty Configuration

# Theme - auto-follow system light/dark mode
window-theme = auto
theme = light:Atom One Light,dark:Atom One Dark

# Window Configuration
window-decoration = false
window-padding-x = 10
window-padding-y = 10
window-vsync = true
window-inherit-working-directory = true
window-save-state = always

# MacOS Specific
macos-non-native-fullscreen = true
macos-titlebar-style = hidden
macos-option-as-alt = true

# Font Configuration
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-feature = calt
font-feature = liga
font-feature = dlig
font-variation = wght=450

# Cursor
cursor-style = block
cursor-style-blink = true
cursor-opacity = 0.7
# cursor-text = background  # Not supported in this version

# Performance
adjust-cell-height = 0
adjust-cell-width = 0

# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Scrollback
scrollback-limit = 10000

# Keybindings
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+enter=new_window
keybind = cmd+t=new_tab
keybind = cmd+shift+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:top
keybind = cmd+down=goto_split:bottom
keybind = cmd+shift+left=resize_split:left,10
keybind = cmd+shift+right=resize_split:right,10
keybind = cmd+shift+up=resize_split:up,10
keybind = cmd+shift+down=resize_split:down,10
keybind = cmd+k=clear_screen
keybind = cmd+shift+c=copy_to_clipboard
keybind = cmd+shift+v=paste_from_clipboard

# Tab Bar
# tab-bar-location = top  # Not supported in this version
# tab-bar-style = minimal  # Not supported in this version

# Color reporting for apps that detect light/dark mode (e.g. OpenCode)
osc-color-report-format = 16-bit

# Misc
confirm-close-surface = false
copy-on-select = true
mouse-hide-while-typing = true
quit-after-last-window-closed = true
# selection-clipboard = true  # Not supported in this version